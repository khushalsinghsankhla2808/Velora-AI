# Required. MongoDB Atlas connection string. Get from: https://www.mongodb.com/cloud/atlas/register
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/velora-db

# Required. Secure 32+ character signing key for JWT auth tokens. Generate via `openssl rand -hex 32`.
JWT_SECRET=your_32_character_jwt_secret_key_here

# Required. OpenRouter API key for DeepSeek/Gemini AI models. Get from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required in production. Razorpay payment gateway API Key ID. Get from: https://razorpay.com/
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# Required in production. Razorpay signature verification secret key. Get from: https://razorpay.com/
RAZORPAY_SECRET=your_razorpay_secret_key_here

# Optional. Port number that the Express API server listens on. Defaults to 8000.
PORT=8000

# Optional. Environment stage: development, production, or test.
NODE_ENV=development

# Required in production. URL of the React frontend application (for CORS configuration).
CLIENT_URL=http://localhost:5173

# Required in production. Client base URL used to construct deployment URLs.
FRONTEND_URL=http://localhost:5173

# Optional. Set to "true" to allow insecure authentication checks in development mode.
ALLOW_INSECURE_DEV_AUTH=false

# Required. Firebase Admin Project ID. Get from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your-firebase-project-id

# Required. Firebase Admin Client Email address. Get from Firebase Console Service Account credentials.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# Required. Firebase Admin private key. Make sure to escape newline characters.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Optional. Full JSON string of the Firebase service account credential file. Alternative to providing email/private key individually.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id"}

# Optional. The primary AI model used for code/website generation. Defaults to deepseek/deepseek-r1.
AI_PRIMARY_MODEL=deepseek/deepseek-r1

# Optional. The fallback AI model used if the primary model fails or times out. Defaults to google/gemini-2.5-flash.
AI_FALLBACK_MODEL=google/gemini-2.5-flash

# Optional. Timeout limit in milliseconds for OpenRouter completions API calls. Defaults to 30000 (30 seconds).
AI_TIMEOUT_MS=30000
