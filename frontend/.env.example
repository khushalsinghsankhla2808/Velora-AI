# Required. Base URL of the backend Express API server.
VITE_SERVER_URL=http://localhost:8000

# Required. Razorpay API Key ID (publicly visible on frontend). Get from: https://razorpay.com/
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# Required. Firebase Web SDK API Key for Client Authentication. Get from: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here

# Required. Firebase Authentication Domain redirect path.
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com

# Required. Firebase Project ID matching the backend configuration.
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional. Firebase Storage bucket URL path (e.g. for image storage).
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# Optional. Firebase Cloud Messaging Sender ID.
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here

# Required. Firebase Web Client App ID.
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id_here
